# LLM 配置（OpenAI 兼容 API，spec 02）
# 复制此文件为 .env 并填入真实值

# API 地址（支持 OpenAI / Azure / Ollama / vLLM 等兼容服务）
LLM_API_ENDPOINT=https://api.openai.com/v1/chat/completions

# API 密钥（必填，为空时 LLM 自动禁用）
LLM_API_KEY=sk-your-key-here

# 模型名称
LLM_MODEL=gpt-4o-mini

# 采样温度（0-2，越高越随机）
LLM_TEMPERATURE=0.7

# 最大响应 token 数
LLM_MAX_TOKENS=256

# 自定义系统提示词（留空使用默认宠物人格）
# LLM_SYSTEM_PROMPT=

# LLM 开关（true/false，false 时永远返回 Stay，行为同 spec 01）
LLM_ENABLED=true

# 宠物 ticker 间隔（毫秒），通过 Vite env 注入前端
VITE_PET_TICKER_INTERVAL_MS=30000
